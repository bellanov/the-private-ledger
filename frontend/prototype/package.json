{
  "name": "htmx-template",
  "version": "1.0.0",
  "description": "A template showing good design patterns with developing in HTMX",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage",
    "test:unit": "jest --coverage --testPathPattern='unit\\.test\\.js$'",
    "test:integration": "jest --coverage --testPathPattern='integration\\.test\\.js$'",
    "test:watch": "jest --watch",
    "lint": "eslint src",
    "format": "eslint src --fix"
  },
  "keywords": [
    "htmx",
    "template",
    "express",
    "html"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "ejs": "^6.0.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.48.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  }
}
